                                            <FontWeight>Normal</FontWeight>
                                            <TextDecoration>None</TextDecoration>
                                            <Color>#000000</Color>
                                          </Style>
                                        </TextRun>
                                        <TextRun>
                                          <Value> In case of non receipt or loss of bill, duplicate bill can be obtained from </Value>
